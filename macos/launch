#!/bin/bash
# macOS .app launcher — opens a file picker for .ipynb files, then runs with uvx juv run.

APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"

# Check if a notebook exists next to the .app (skip picker if so)
NOTEBOOK=""
for f in "$APP_DIR"/*.ipynb; do
  [ -f "$f" ] && NOTEBOOK="$f" && break
done

if [ -z "$NOTEBOOK" ]; then
  # Show file picker for .ipynb files
  NOTEBOOK=$(osascript -e 'try
    set theFile to choose file with prompt "Select a Jupyter notebook (.ipynb):" of type {"public.item"} default location (path to home folder)
    return POSIX path of theFile
  on error
    return ""
  end try' 2>/dev/null)

  if [ -z "$NOTEBOOK" ]; then
    exit 0
  fi

  # Verify it's a .ipynb file
  case "$NOTEBOOK" in
    *.ipynb) ;;
    *)
      osascript -e 'display alert "Error" message "Please select a .ipynb file."'
      exit 1
      ;;
  esac
fi

NOTEBOOK_DIR="$(dirname "$NOTEBOOK")"
NOTEBOOK_NAME="$(basename "$NOTEBOOK")"

# Write a temp runner script to avoid escaping issues with osascript
RUNNER=$(mktemp /tmp/juv-runner.XXXXXX)
cat > "$RUNNER" << SCRIPT
#!/bin/bash
export PATH="\$HOME/.local/bin:\$PATH"
if ! command -v uv >/dev/null 2>&1; then
  echo "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  export PATH="\$HOME/.local/bin:\$PATH"
fi
cd "$NOTEBOOK_DIR"
echo "Launching $NOTEBOOK_NAME ..."
uvx juv run "$NOTEBOOK_NAME"
rm -f "$RUNNER"
SCRIPT
chmod +x "$RUNNER"

osascript -e "tell application \"Terminal\"
  activate
  do script \"'${RUNNER}'\"
end tell"
