#!/bin/bash
# macOS .app launcher — opens a file picker for .ipynb/.py files, then runs
# with uvx juv run (Jupyter), uvx marimo edit --sandbox (marimo), or uv run (plain .py).

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUNDLE_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
APP_DIR="$(dirname "$BUNDLE_DIR")"

# macOS App Translocation: quarantined apps silently run from a random temp path,
# so APP_DIR would point to an empty temp folder instead of the real location.
# Detect this and resolve the original .app path via Spotlight.
if [[ "$APP_DIR" == /private/var/folders/*/AppTranslocation/* ]]; then
  ORIG_BUNDLE="$(mdfind "kMDItemCFBundleIdentifier == 'com.launcher723.app'" 2>/dev/null | head -1)"
  [ -d "$ORIG_BUNDLE" ] && APP_DIR="$(dirname "$ORIG_BUNDLE")"
fi

# Check if exactly one notebook exists next to the .app (skip picker if so)
NOTEBOOK=""
NOTEBOOK_COUNT=0
for f in "$APP_DIR"/*.ipynb "$APP_DIR"/*.py; do
  [ -f "$f" ] && NOTEBOOK_COUNT=$((NOTEBOOK_COUNT + 1)) && NOTEBOOK="$f"
done
[ "$NOTEBOOK_COUNT" -ne 1 ] && NOTEBOOK=""

if [ -z "$NOTEBOOK" ]; then
  # Show file picker for .ipynb and .py files
  NOTEBOOK=$(osascript -e 'try
    set theFile to choose file with prompt "Select a notebook (.ipynb or .py):" of type {"public.item"} default location (path to home folder)
    return POSIX path of theFile
  on error
    return ""
  end try' 2>/dev/null)

  if [ -z "$NOTEBOOK" ]; then
    exit 0
  fi

  # Verify it's a supported file type
  case "$NOTEBOOK" in
    *.ipynb|*.py) ;;
    *)
      osascript -e 'display alert "Error" message "Please select a .ipynb or .py file."'
      exit 1
      ;;
  esac
fi

NOTEBOOK_DIR="$(dirname "$NOTEBOOK")"
NOTEBOOK_NAME="$(basename "$NOTEBOOK")"

# Choose the right command based on file extension (and marimo dependency for .py)
case "$NOTEBOOK_NAME" in
  *.ipynb) RUN_CMD="uvx juv run" ;;
  *.py)
    if grep -q '"marimo' "$NOTEBOOK"; then
      RUN_CMD="uvx marimo edit --sandbox"
    else
      RUN_CMD="uv run"
    fi
    ;;
esac

# Write a temp runner script to avoid escaping issues with osascript
RUNNER=$(mktemp /tmp/notebook-launcher-runner.XXXXXX)
cat > "$RUNNER" << SCRIPT
#!/bin/bash
export PATH="\$HOME/.local/bin:\$PATH"
if ! command -v uv >/dev/null 2>&1; then
  echo "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  export PATH="\$HOME/.local/bin:\$PATH"
fi
cd "$NOTEBOOK_DIR"
echo "Launching $NOTEBOOK_NAME ..."
$RUN_CMD "$NOTEBOOK_NAME"
rm -f "$RUNNER"
SCRIPT
chmod +x "$RUNNER"

osascript -e "tell application \"Terminal\"
  activate
  do script \"'${RUNNER}'\"
end tell"
